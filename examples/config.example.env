# Copy to .env and edit locally. Never commit .env.
CLASH_SUBSCRIPTION_URL="[REDACTED]"
CLIPROXY_BASE_URL="http://127.0.0.1:8317"
CLIPROXY_API_KEY="***"
CLIPROXY_WORKDIR="$HOME/cliproxyapi"
CLIPROXY_CONFIG_PATH="$HOME/cliproxyapi/config.yaml"
CLIPROXY_BINARY_PATH="$HOME/cliproxyapi/cli-proxy-api"
CLIPROXY_SERVICE_NAME="cliproxyapi.service"
CLIPROXY_PROXY_URL="http://127.0.0.1:7890"
CLIPROXY_PORT="8317"
MIHOMO_VERSION="v1.19.24"
MIHOMO_BINARY_PATH="/usr/local/bin/mihomo"
MIHOMO_CONFIG_DIR="$HOME/clashd"
MIHOMO_CONFIG_PATH="$HOME/clashd/config.yaml"
MIHOMO_SERVICE_NAME="clash.service"
ANTHROPIC_MODEL="gpt-5.5"
CODEX_MODEL="gpt-5.5"
INSTALL_HERMES=0
INSTALL_MIHOMO=0
INSTALL_CLIPROXYAPI=0
INSTALL_CLAUDE=1
INSTALL_CODEX=1
INSTALL_CC_SWITCH=1
INSTALL_SHELL=1
